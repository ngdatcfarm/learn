# =====================================================================
# MySQL — Thông tin kết nối database
# Lấy từ hosting control panel (cPanel / aaPanel / DirectAdmin) hoặc
# từ phpMyAdmin (góc phải trên cùng: "Server: X.X.X.X")
# =====================================================================

# Host MySQL (thường là "localhost" nếu app + DB cùng server)
MYSQL_HOST=localhost

# Port (mặc định 3306, để trống nếu không chắc)
MYSQL_PORT=3306

# User database (tạo trong phpMyAdmin → Privileges → Add user)
MYSQL_USER=learn_user

# Password (KHÔNG commit — chỉ điền vào file .env local)
MYSQL_PASSWORD=change_me_strong_password

# Tên database (tạo trong phpMyAdmin → Databases → Create)
# Charset/collation: utf8mb4 / utf8mb4_unicode_ci
MYSQL_DATABASE=learn_cfarm

# Connection pool size (mặc định 10 — đủ cho 10 HS)
MYSQL_POOL_SIZE=10


# =====================================================================
# App config
# =====================================================================

# Port cho Express server (mặc định 3000)
PORT=3000

# Môi trường: "development" | "production"
NODE_ENV=development


# =====================================================================
# Admin account (chỉ dùng lần đầu setup, đổi pass sau khi deploy)
# =====================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123


# =====================================================================
# Gemini AI — optional, cho AI tutor endpoints
# Lấy từ: https://aistudio.google.com/app/apikey
# Nếu bỏ trống → AI endpoints chạy chế độ offline fallback
# =====================================================================
GEMINI_API_KEY=MY_GEMINI_API_KEY


# =====================================================================
# App URL (cho OAuth callbacks, self-referential links)
# =====================================================================
APP_URL=http://localhost:3000


# =====================================================================
# TURN server (Live Help voice + screen share)
# Provider chính: Twilio Network Traversal Service (NTS).
# Setup: Twilio Console → Account → API keys & tokens → lấy Account SID
#        + Auth Token (KHÔNG phải API Key SID/Secret — Twilio SDK dùng
#        Account SID + Auth Token cho `client.tokens.create()`).
#
# ⚠️ SECURITY: TWILIO_AUTH_TOKEN = MASTER credential (full account access).
#    CHỈ dùng trong server-side SDK call. KHÔNG BAO GIỜ lộ xuống client.
#    SDK tự sinh ephemeral username + credential (TTL 24h) trả về cho app.
#
# Alternative: cfarm self-hosted coturn (chỉ work LAN test, không phải production).
# Generate secret: openssl rand -hex 32
# =====================================================================

# Twilio NTS (mặc định — recommended cho production)
TURN_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here_keep_secret

# (optional - rollback về cfarm nếu cần LAN test)
# TURN_PROVIDER=cfarm
# TURN_HOST=turn.example.com
# TURN_SECRET=replace_with_64_hex_chars


# =====================================================================
# Upload directory (Step 9a) — nơi lưu audio HS thu âm
# Mặc định: <project>/uploads (đủ cho local dev)
# Production (cfarm.vn): /var/www/learn/uploads
#   → sudo mkdir -p /var/www/learn/uploads/audio
#   → sudo chown -R $USER:$USER /var/www/learn
# =====================================================================
# UPLOAD_DIR=/var/www/learn/uploads


# =====================================================================
# Backup tự động (Step 10a) — mysqldump daily qua in-process cron
# Job chạy hourly, chỉ thực sự dump khi NOW() trong cửa sổ ±15 phút
# của BACKUP_HOUR (mặc định 03:00 sáng local time).
# Giữ lại 7 file gần nhất, file cũ hơn tự động xoá (rotation).
# Yêu cầu `mysqldump` + `gzip` có trên PATH (mặc định trên cfarm.vn).
# =====================================================================
# Backup directory (mặc định: <project>/backups)
# Production nên dùng path tuyệt đối, vd /var/backups/learn
# BACKUP_DIR=/var/backups/learn

# Giờ chạy backup (0-23, mặc định 3 = 03:00 sáng)
# BACKUP_HOUR=3
